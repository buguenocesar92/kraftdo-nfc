# Archivo de configuración para desarrollo local con Docker
# Copia este archivo a .env.docker.local y ajusta los valores según tu entorno

# Aplicación
APP_KEY=base64:GENERA_UNA_NUEVA_CLAVE_CON_php_artisan_key:generate
APP_URL=http://localhost:9090

# Base de datos local
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=nfc_dynamic_app
DB_USERNAME=nfc_user
DB_PASSWORD=tu_password_local

# Para usar con docker-compose:
# 1. Copia este archivo a .env.docker.local
# 2. Ajusta las variables según tu configuración local
# 3. Ejecuta: docker-compose -f docker-compose.local.yml --env-file .env.docker.local up