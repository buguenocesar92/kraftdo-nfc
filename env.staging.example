# ===========================================
# STAGING CONFIGURATION - KRAFTDO NFC
# ===========================================
APP_NAME="KraftDo NFC Staging"
APP_ENV=staging
APP_DEBUG=true
APP_URL=https://staging.kraftdo.cl
ASSET_URL=https://staging.kraftdo.cl
LIVEWIRE_ASSET_URL=https://staging.kraftdo.cl

# Application Key (genera con: php artisan key:generate)
APP_KEY=

# ===========================================
# DOCKER CONFIGURATION
# ===========================================
APP_PORT=8084
COMPOSE_PROJECT_NAME=kraftdo-nfc-staging

# ===========================================
# DATABASE (EXTERNAL MYSQL)
# ===========================================
DB_CONNECTION=mysql
DB_HOST=your-mysql-host-ip
DB_PORT=3306
DB_DATABASE=kraftdo_nfc_staging
DB_USERNAME=kraftdo_staging
DB_PASSWORD=your-staging-mysql-password
DB_SSLMODE=PREFER

# ===========================================
# REDIS CONFIGURATION (STAGING)
# ===========================================
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PASSWORD=your-staging-redis-password
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# Separate Redis databases for staging
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# ===========================================
# SESSION CONFIGURATION
# ===========================================
SESSION_DOMAIN=kraftdo.cl
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_ENCRYPT=true
SESSION_LIFETIME=120

# ===========================================
# PHP-FPM CONFIGURATION (No Octane)
# ===========================================
# This staging environment uses PHP-FPM + Nginx
# Octane is not available in this configuration

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=debug
LOG_CHANNEL=daily

# ===========================================
# MAIL CONFIGURATION
# ===========================================
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# ===========================================
# PERFORMANCE
# ===========================================
CONFIG_CACHE=false
ROUTE_CACHE=false
VIEW_CACHE=false
OPTIMIZE_CLEAR=true