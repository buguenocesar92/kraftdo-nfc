# .dockerignore para Laravel NFC con Nginx + PHP-FPM
# Optimizado para reducir tamaño de imagen y mejorar velocidad de build

# VERSION CONTROL
.git
.gitignore
.gitattributes
.github

# DOCUMENTACIÓN
README.md
*.md
CHANGELOG*
LICENSE*

# IDE Y EDITORES
.vscode
.idea
*.swp
*.swo
.DS_Store

# NODE.JS
node_modules
npm-debug.log*
yarn-debug.log*
.npmrc
package-lock.json.bak

# COMPOSER Y PHP
# /vendor - Comentado para permitir multi-stage build
composer.lock.bak
.phpunit.result.cache

# LARAVEL STORAGE (se monta como volumen)
/storage/app/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
!/storage/app/.gitignore
!/storage/framework/.gitignore
!/storage/logs/.gitignore

# BOOTSTRAP CACHE (se monta como volumen)
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

# ENVIRONMENT
.env*
!.env.example
!.env.docker
!.env

# DOCKER
docker-compose.override.yml
Dockerfile.local

# TESTING
.phpunit.cache
coverage.xml
junit.xml

# LOGS Y TEMPORALES
*.log
*.tmp
temp
backups/

# ASSETS COMPILADOS
/public/build
/public/hot
/public/storage

# SECURITY
.secrets
private_key*
*.pem
*.key