# Caddyfile Híbrido: FrankenPHP sirve assets + proxy a PHP-FPM
{
    auto_https off
    admin off
    log {
        output stdout
        format console
    }
}

:80 {
    root * /var/www/html/public

    # ==========================================
    # STORAGE PÚBLICO (proxy a PHP-FPM) - PRIORIDAD ALTA
    # ==========================================
    handle /storage/* {
        header Cache-Control "no-cache, no-store, must-revalidate"
        header Pragma "no-cache"
        header Expires "0"
        header X-Served-By "PHP-FPM-Storage"
        reverse_proxy php-fpm:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ==========================================
    # ASSETS BUILD (Vite compilados)
    # ==========================================
    handle /build/* {
        header Cache-Control "public, max-age=31536000, immutable"
        header X-Served-By "FrankenPHP-Build"
        file_server
    }

    # ==========================================
    # ASSETS ESTÁTICOS (servidos por FrankenPHP) - EXCLUYENDO STORAGE
    # ==========================================
    @static {
        path *.css *.js *.ico *.png *.jpg *.jpeg *.gif *.webp *.svg *.woff *.woff2 *.ttf *.eot *.pdf *.zip *.map
        not path /storage/*
    }
    handle @static {
        header Cache-Control "public, max-age=31536000, immutable"
        header X-Served-By "FrankenPHP-Static"
        file_server {
            precompressed gzip br
        }
    }

    # ==========================================
    # FILAMENT ASSETS (específicos)
    # ==========================================
    @filament_assets {
        path /css/filament/* /js/filament/* /fonts/filament/*
    }
    handle @filament_assets {
        header Cache-Control "public, max-age=86400"  
        header X-Served-By "FrankenPHP-Filament"
        file_server
    }

    # ==========================================
    # LIVEWIRE ASSETS (servidos por FrankenPHP)
    # ==========================================
    handle /livewire/livewire.js {
        header Cache-Control "public, max-age=86400"
        header X-Served-By "FrankenPHP-Livewire"
        reverse_proxy php-fpm:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ==========================================
    # HEALTH CHECK (respondido por FrankenPHP)
    # ==========================================
    handle /health {
        header Content-Type "application/json"
        respond `{"status":"ok","frontend":"frankenphp","backend":"php-fpm","timestamp":"{time.now}"}` 200
    }

    # ==========================================
    # API ROUTES (proxy a PHP-FPM)
    # ==========================================
    @api path /api/*
    handle @api {
        header X-Served-By "PHP-FPM-API"
        reverse_proxy php-fpm:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ==========================================
    # ADMIN PANEL (proxy a PHP-FPM)
    # ==========================================
    @admin path /admin*
    handle @admin {
        header X-Served-By "PHP-FPM-Admin"
        reverse_proxy php-fpm:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ==========================================
    # LIVEWIRE UPDATE (proxy a PHP-FPM)
    # ==========================================
    @livewire path /livewire/*
    handle @livewire {
        header X-Served-By "PHP-FPM-Livewire"
        reverse_proxy php-fpm:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ==========================================
    # RUTA RAÍZ (siempre a PHP-FPM)
    # ==========================================
    handle / {
        header X-Served-By "PHP-FPM-Root"
        reverse_proxy php-fpm:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ==========================================
    # TODAS LAS DEMÁS RUTAS (proxy a PHP-FPM)
    # ==========================================
    handle {
        # Primero intentar servir archivo estático (EXCLUYENDO .php)
        @file {
            file {path}
            not path *.php
        }
        handle @file {
            header X-Served-By "FrankenPHP-File"
            file_server
        }

        # Todas las rutas dinámicas y archivos .php van a PHP-FPM
        header X-Served-By "PHP-FPM-Laravel" 
        reverse_proxy php-fpm:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Headers de seguridad
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"  
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        -X-Powered-By
    }

    # Logs de acceso
    log {
        output stdout
        format console
    }
}