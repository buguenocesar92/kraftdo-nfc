# PHPStan Configuration for KraftDo NFC
# Static analysis tool for PHP code quality

parameters:
    level: 8
    paths:
        - app
        - config
        - database/factories
        - database/seeders
        - routes
    
    excludePaths:
        - bootstrap/
        - storage/
        - vendor/
        - node_modules/
        - public/build/
        - tests/
    
    ignoreErrors:
        # Laravel-specific patterns that are safe to ignore
        - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Builder#'
        - '#Call to an undefined method Illuminate\\Database\\Query\\Builder#'
        - '#Method .* should return .* but returns Illuminate\\Database\\Eloquent\\Builder#'
        
        # Livewire component properties
        - '#Property .* has no type specified#'
        - '#Method .* has parameter .* with no type specified#'
        
        # Filament Admin Panel
        - '#Call to an undefined method Filament\\#'
        - '#Property .* \(Filament\\.*\) does not accept#'
    
    checkMissingIterableValueType: false
    checkGenericClassInNonGenericObjectType: false
    
    # Laravel-specific extensions
    scanFiles:
        - vendor/laravel/framework/src/Illuminate/Foundation/helpers.php
        - vendor/laravel/framework/src/Illuminate/Support/helpers.php
    
    # Include Larastan for Laravel-specific analysis
    includes:
        - vendor/larastan/larastan/extension.neon
    
    # Custom rules for better analysis
    universalObjectCratesClasses:
        - Illuminate\Http\Request
        - Illuminate\Support\Collection
        
    # Treat mixed as any for better Laravel compatibility
    treatPhpDocTypesAsCertain: false
    
    # Memory limit for large codebases
    memoryLimitFile: 1G
    
    # Parallel processing
    parallel:
        jobSize: 20
        maximumNumberOfProcesses: 4
        minimumNumberOfJobsPerProcess: 2