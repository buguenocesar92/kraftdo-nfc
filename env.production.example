# Variables de Entorno para Producción - Laravel NFC App
# Copia este archivo como .env.production y configura los valores reales

# ===========================================
# CONFIGURACIÓN DE DOCKER COMPOSE
# ===========================================
ENVIRONMENT=prod
IMAGE_TAG=latest
APP_PORT=8080

# Recursos optimizados para producción
MEMORY_LIMIT=512M
CPU_LIMIT=0.75
MEMORY_RESERVATION=256M
CPU_RESERVATION=0.25

# Configuración de Laravel Octane para producción
OCTANE_SERVER=swoole
OCTANE_WORKERS=auto
OCTANE_MAX_REQUESTS=1000
OCTANE_HOST=0.0.0.0
OCTANE_PORT=8080

# ===========================================
# CONFIGURACIÓN DE APLICACIÓN
# ===========================================
APP_NAME="NFC Dynamic App"
APP_ENV=production
APP_KEY=base64:GENERAR_CON_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://tu-dominio.com:8080
ASSET_URL=https://tu-dominio.com:8080

# Configuración para URLs limpias (sin index.php)
APP_FORCE_HTTPS=false
FORCE_HTTPS=false

# ===========================================
# BASE DE DATOS EXTERNA
# ===========================================
DB_CONNECTION=mysql
DB_HOST=192.168.1.100  # IP del servidor MySQL externo
DB_PORT=3306
DB_DATABASE=nfc_dynamic_app
DB_USERNAME=nfc_user
DB_PASSWORD=password_seguro_aqui

# ===========================================
# CACHE Y SESIONES (REDIS RECOMENDADO PARA OCTANE)
# ===========================================
# Opciones: file, redis, database
CACHE_DRIVER=redis
CACHE_PREFIX=nfc_prod
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=.tu-dominio.com
SESSION_SAME_SITE=strict
QUEUE_CONNECTION=redis

# ===========================================
# REDIS CONFIGURATION (INTERNO O EXTERNO)
# ===========================================
# Para usar Redis interno (container): REDIS_HOST=redis
# Para usar Redis externo: REDIS_HOST=192.168.1.101
REDIS_HOST=redis
REDIS_PASSWORD=secure_redis_password
REDIS_PORT=6379
REDIS_DB=0
REDIS_CLIENT=phpredis
REDIS_TIMEOUT=5
REDIS_READ_TIMEOUT=60

# Redis Database Allocation
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# Redis Memory Configuration
REDIS_MAX_MEMORY=256mb
REDIS_MEMORY_LIMIT=512M
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_RESERVATION=256M
REDIS_CPU_RESERVATION=0.25

# ===========================================
# CONFIGURACIÓN DE CORREO
# ===========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@tu-dominio.com
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# CONFIGURACIÓN DE ARCHIVOS
# ===========================================
FILESYSTEM_DISK=local
# Para usar S3, configura:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=

# ===========================================
# CONFIGURACIÓN DE LOGS
# ===========================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ===========================================
# CONFIGURACIÓN DE BROADCAST
# ===========================================
BROADCAST_DRIVER=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ===========================================
# CONFIGURACIÓN DE VITE (PRODUCCIÓN)
# ===========================================
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ===========================================
# CONFIGURACIÓN DE MIGRACIONES
# ===========================================
# Cambiar a true SOLO para la primera ejecución
RUN_MIGRATIONS=false

# ===========================================
# CONFIGURACIÓN DE SEGURIDAD
# ===========================================
# Configurar según tu dominio
SESSION_DOMAIN=.tu-dominio.com
SANCTUM_STATEFUL_DOMAINS=tu-dominio.com,www.tu-dominio.com

# ===========================================
# CONFIGURACIÓN ESPECÍFICA DE NFC
# ===========================================
# Agregar aquí configuraciones específicas de tu aplicación NFC
NFC_MAX_UPLOAD_SIZE=10240  # KB
NFC_ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif
NFC_ALLOWED_AUDIO_TYPES=mp3,wav,ogg
NFC_ALLOWED_VIDEO_TYPES=mp4,webm,avi 