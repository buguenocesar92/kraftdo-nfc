# ===========================================
# PRODUCTION CONFIGURATION - KRAFTDO NFC
# ===========================================
APP_NAME="KraftDo NFC"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://nfc.kraftdo.cl
ASSET_URL=https://nfc.kraftdo.cl
LIVEWIRE_ASSET_URL=https://nfc.kraftdo.cl

# Application Key (genera con: php artisan key:generate)
APP_KEY=

# ===========================================
# DOCKER CONFIGURATION
# ===========================================
APP_PORT=8085
COMPOSE_PROJECT_NAME=kraftdo-nfc-prod

# ===========================================
# DATABASE (EXTERNAL MYSQL)
# ===========================================
DB_CONNECTION=mysql
DB_HOST=your-mysql-host-ip
DB_PORT=3306
DB_DATABASE=kraftdo_nfc_prod
DB_USERNAME=kraftdo_prod
DB_PASSWORD=your-production-mysql-password
DB_SSLMODE=REQUIRE

# ===========================================
# REDIS CONFIGURATION (PRODUCTION)
# ===========================================
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PASSWORD=your-production-redis-password
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# Separate Redis databases for production
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# ===========================================
# SECURITY SETTINGS (PRODUCTION)
# ===========================================
SESSION_DOMAIN=kraftdo.cl
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_ENCRYPT=true
SESSION_LIFETIME=120

# ===========================================
# SSL/TLS CONFIGURATION
# ===========================================
SERVER_NAME=kraftdo.cl:8085
HTTPS_ONLY=true
SSL_CERT_PATH=/etc/ssl/certs/kraftdo.crt
SSL_KEY_PATH=/etc/ssl/private/kraftdo.key
ENABLE_SECURITY_HEADERS=true
FORCE_HTTPS=true


# Redis optimization
REDIS_MAX_MEMORY=2gb

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=warning
LOG_CHANNEL=daily
LOG_SLACK_WEBHOOK_URL=

# ===========================================
# OPTIMIZATION FLAGS
# ===========================================
CONFIG_CACHE=true
ROUTE_CACHE=true
VIEW_CACHE=true
OPTIMIZE_CLEAR=false