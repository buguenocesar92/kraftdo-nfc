# ===========================================
# PRODUCTION CONFIGURATION - NFC KRAFTDO
# ===========================================
APP_NAME="KraftDo NFC"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com
ASSET_URL=https://your-domain.com

# ===========================================
# DATABASE (EXTERNAL MYSQL)
# ===========================================
DB_CONNECTION=mysql
DB_HOST=your-mysql-host-ip
DB_PORT=3306
DB_DATABASE=kraftdo
DB_USERNAME=kraftdo_user
DB_PASSWORD=your-secure-mysql-password

# ===========================================
# REDIS CONFIGURATION (PRODUCTION)
# ===========================================
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=your-redis-host-ip
REDIS_PASSWORD=your-secure-redis-password
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# Separate Redis databases for production
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# ===========================================
# SECURITY SETTINGS (PRODUCTION)
# ===========================================
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_ENCRYPT=true
SESSION_LIFETIME=120

# ===========================================
# PERFORMANCE OPTIMIZATION
# ===========================================
OCTANE_SERVER=swoole
OCTANE_WORKERS=auto
OCTANE_MAX_REQUESTS=1000

# Logging optimized for production
LOG_LEVEL=error
LOG_CHANNEL=daily

# ===========================================
# OPTIMIZATION FLAGS
# ===========================================
CONFIG_CACHE=true
ROUTE_CACHE=true
VIEW_CACHE=true
OPTIMIZE_CLEAR=false