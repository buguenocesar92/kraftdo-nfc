# ===========================================
# KRAFTDO NFC - ENVIRONMENT TEMPLATE
# ===========================================
# Este archivo contiene todas las variables de entorno necesarias
# para el proyecto KraftDo NFC. Copiar como .env y completar valores.

# ===========================================
# APLICACIÓN - CONFIGURACIÓN BÁSICA
# ===========================================
APP_NAME="KraftDo NFC"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
ASSET_URL=${APP_URL}
LIVEWIRE_ASSET_URL=${APP_URL}
APP_TIMEZONE=UTC
APP_LOCALE=es
APP_FALLBACK_LOCALE=en

# ===========================================
# PUERTOS Y NETWORKING
# ===========================================
# Puertos principales
APP_PORT=8080
APP_SSL_PORT=8443
VITE_PORT=5173

# Puertos de servicios
DB_PORT=3306
REDIS_PORT=6379
MAILHOG_PORT=8025

# Network Configuration
TRUSTED_PROXIES=*
APP_FORCE_HTTPS=false

# ===========================================
# BASE DE DATOS
# ===========================================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=kraftdo_nfc
DB_USERNAME=kraftdo
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SSLMODE=DISABLED

# SQLite (alternativa para desarrollo)
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# ===========================================
# REDIS - CACHE, SESIONES Y COLAS
# ===========================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

# Bases de datos específicas por funcionalidad
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# Configuraciones de conexión
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default

# Cache y Session Drivers
CACHE_DRIVER=redis
CACHE_PREFIX=kraftdo_nfc_cache
SESSION_DRIVER=redis
SESSION_CONNECTION=default
QUEUE_CONNECTION=redis

# ===========================================
# CONFIGURACIÓN DE SESIONES
# ===========================================
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_ENCRYPT=false

# ===========================================
# LOGGING Y DEBUGGING
# ===========================================
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null
LOG_STACK=single


# ===========================================
# PHP-FPM & NGINX CONFIGURATION
# ===========================================
PHP_FPM_LISTEN=127.0.0.1:9000
NGINX_ROOT=/var/www/html/public

# ===========================================
# PERFORMANCE & CACHING
# ===========================================
# OPcache
OPCACHE_ENABLE=1
OPCACHE_MEMORY_CONSUMPTION=256
OPCACHE_MAX_ACCELERATED_FILES=10000
OPCACHE_VALIDATE_TIMESTAMPS=1
OPCACHE_REVALIDATE_FREQ=0

# View Cache
VIEW_CACHE_PATH=storage/framework/views

# ===========================================
# QUEUE WORKERS
# ===========================================
QUEUE_WORKER=false
QUEUE_TIMEOUT=90
QUEUE_TRIES=3
QUEUE_WORKERS=1
QUEUE_BACKOFF=3
QUEUE_MAX_JOBS=1000

# ===========================================
# MAIL CONFIGURATION
# ===========================================
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@kraftdo.com"
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# FILESYSTEM & STORAGE
# ===========================================
FILESYSTEM_DISK=local
STORAGE_PATH=./storage

# AWS S3 (opcional)
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ===========================================
# BROADCASTING
# ===========================================
BROADCAST_DRIVER=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ===========================================
# SECURITY & NFC
# ===========================================
NFC_ENABLED=true
HTTPS_ONLY=false
NFC_TOKEN_EXPIRY=365
NFC_MAX_TOKENS_PER_USER=10

# CORS Configuration
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=*
CORS_ALLOWED_HEADERS=*

# ===========================================
# SERVICIOS EXTERNOS
# ===========================================
# Google Services
GOOGLE_MAPS_API_KEY=
GOOGLE_ANALYTICS_ID=

# Social Media APIs
FACEBOOK_APP_ID=
TWITTER_API_KEY=
INSTAGRAM_API_KEY=

# ===========================================
# MONITORING & ANALYTICS
# ===========================================
# Error Tracking
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# Performance Monitoring
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME="${APP_NAME}"

# ===========================================
# DEVELOPMENT TOOLS
# ===========================================
# Laravel Debugbar
DEBUGBAR_ENABLED=true

# Laravel Telescope
TELESCOPE_ENABLED=false

# Hot Reload & Development
VITE_HMR=true
VITE_HMR_HOST=localhost
VITE_HMR_PORT=${VITE_PORT}

# ===========================================
# CONTAINER SPECIFIC
# ===========================================
# Docker Compose Override
COMPOSE_PROJECT_NAME=kraftdo-nfc
COMPOSE_FILE=docker-compose.yml

# Resource Limits
MEMORY_LIMIT=512M
MAX_EXECUTION_TIME=300
UPLOAD_MAX_FILESIZE=50M
POST_MAX_SIZE=50M

# Health Checks
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_START_PERIOD=60s

# ===========================================
# BACKUP & MAINTENANCE
# ===========================================
BACKUP_ENABLED=false
BACKUP_DISK=local
BACKUP_SCHEDULE="0 2 * * *"
MAINTENANCE_MODE=false

# ===========================================
# API KEYS & TOKENS
# ===========================================
# JWT Configuration
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# API Rate Limiting
API_RATE_LIMIT=60
API_THROTTLE_MIDDLEWARE=throttle:api

# ===========================================
# THIRD PARTY INTEGRATIONS
# ===========================================
# Payment Gateways
STRIPE_KEY=
STRIPE_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# SMS Services
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Cloud Storage
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=