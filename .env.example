# ===========================================
# APP CONFIG
# ===========================================
APP_NAME="KraftDo NFC"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.kraftdo.cl
ASSET_URL=https://staging.kraftdo.cl
LIVEWIRE_ASSET_URL=https://staging.kraftdo.cl

# ===========================================
# DATABASE (MySQL Externa)
# ===========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kraftdo
DB_USERNAME=root
DB_PASSWORD=

# ===========================================
# REDIS CONFIG (Staging/Production)
# ===========================================
REDIS_HOST=kraftdo-nfc-staging-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===========================================
# SESSION CONFIG (Staging/Production)
# ===========================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=kraftdo.cl
SESSION_SECURE_COOKIE=true

# ===========================================
# CACHE CONFIG (Staging/Production) 
# ===========================================
CACHE_DRIVER=redis

# ===========================================
# QUEUE CONFIG (Staging/Production)
# ===========================================
QUEUE_CONNECTION=redis

# ===========================================
# MAIL CONFIG
# ===========================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# AWS S3 (para subida de archivos)
# ===========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ===========================================
# PUSHER (WebSockets)
# ===========================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ===========================================
# SECURITY CONFIG (Production)
# ===========================================
# Telescope (disable in production)
TELESCOPE_ENABLED=false

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# HTTPS & Security
FORCE_HTTPS=true
SECURE_HEADERS=true

# Rate limiting
THROTTLE_REQUESTS_PER_MINUTE=60

# File uploads
UPLOAD_MAX_FILESIZE=10M
POST_MAX_SIZE=10M

# ===========================================
# CUSTOM CONFIG
# ===========================================
FILAMENT_ADMIN_USER_NAME="Admin"
FILAMENT_ADMIN_USER_EMAIL="admin@kraftdo.cl"
FILAMENT_ADMIN_USER_PASSWORD="password"